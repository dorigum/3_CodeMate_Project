DOCKER_IMAGE=docker-hub-username/codemate
IMAGE_TAG=latest
APP_PORT=8080

CODEMATE_DB_NAME=codemate
CODEMATE_DB_USERNAME=codemate
CODEMATE_DB_PASSWORD=change-me
CODEMATE_DB_USE_SSL=false
MYSQL_ROOT_PASSWORD=change-root-password

CODEMATE_JWT_SECRET=replace-with-a-base64-encoded-secret-at-least-32-bytes
CODEMATE_JWT_ACCESS_TOKEN_VALIDITY_MILLISECONDS=3600000
CODEMATE_JWT_REFRESH_TOKEN_VALIDITY_MILLISECONDS=1209600000
